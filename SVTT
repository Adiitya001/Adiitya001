Q8. Design and implement mouse and keyboard actions using the Actions class for advanced interactions.
# Experiment 8: Mouse and Keyboard Actions using Actions class

from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.action_chains import ActionChains
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager
import time

# Step 1: Setup WebDriver
driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()))

# Step 2: Open demo site
driver.get("https://the-internet.herokuapp.com/drag_and_drop")
driver.maximize_window()
time.sleep(2)

# Step 3: Create Actions object
actions = ActionChains(driver)

# ----------- DRAG AND DROP -----------
source = driver.find_element(By.ID, "column-a")
target = driver.find_element(By.ID, "column-b")

actions.drag_and_drop(source, target).perform()
time.sleep(2)

# ----------- MOUSE HOVER -----------
driver.get("https://the-internet.herokuapp.com/hovers")
time.sleep(2)

hover_element = driver.find_element(By.XPATH, "(//div[@class='figure'])[1]")
actions.move_to_element(hover_element).perform()
time.sleep(2)

# ----------- KEYBOARD ACTION -----------
driver.get("https://www.google.com")
time.sleep(2)

search_box = driver.find_element(By.NAME, "q")
search_box.send_keys("Selenium")

# Press ENTER using Actions
actions.send_keys("\n").perform()

time.sleep(3)

# Step 4: Close browser
driver.quit()
