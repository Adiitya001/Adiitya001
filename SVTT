Q3. Design and implement locators to find web elements using ID, XPath, or CSS selectors.
# Experiment 3: Locators (Working Version)

from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager
import time

# Setup WebDriver
driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()))

# Open stable demo site
driver.get("https://the-internet.herokuapp.com/login")
driver.maximize_window()
time.sleep(2)

# ----------- ID LOCATOR -----------
driver.find_element(By.ID, "username").send_keys("tomsmith")

# ----------- CSS SELECTOR -----------
driver.find_element(By.CSS_SELECTOR, "#password").send_keys("SuperSecretPassword!")

# ----------- XPATH LOCATOR -----------
driver.find_element(By.XPATH, "//button[@type='submit']").click()

time.sleep(3)

driver.quit()
