Q9. Design and implement web table interaction to extract and process data from table elements.
# Experiment 9: Web Table Handling in Selenium

from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.service import Service
from webdriver_manager.chrome import ChromeDriverManager
import time

# Step 1: Setup WebDriver
driver = webdriver.Chrome(service=Service(ChromeDriverManager().install()))

# Step 2: Open website with table
driver.get("https://the-internet.herokuapp.com/tables")
driver.maximize_window()
time.sleep(2)

# Step 3: Locate all rows in table
rows = driver.find_elements(By.XPATH, "//table[@id='table1']//tbody/tr")

# Step 4: Extract data from table
print("Table Data:\n")

for row in rows:
    columns = row.find_elements(By.TAG_NAME, "td")
    for col in columns:
        print(col.text, end=" | ")
    print()   # New line for each row

time.sleep(2)

# Step 5: Close browser
driver.quit()
